from pyspark.sql.functions import col, sum
df.select([sum(col(c).isNull().cast("int")).alias(c) for c in df.columns]).show()
df.groupBy("Type").count().show()
df.groupBy("Type").avg("Sentiment").show()
df.groupBy("Type").avg("ResponseTime").show()
df.stat.corr("ResponseTime", "Sentiment")
df.groupBy("Sentiment").count().orderBy("Sentiment").show()
df.groupBy("CustomerID").count().orderBy("count", ascending=False).show()
df.groupBy("CustomerID").avg("Sentiment").orderBy("avg(Sentiment)").show()
